    <Cell ss:StyleID="s72"/>
    <Cell ss:StyleID="s72"/>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">1.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">CSR Section 5.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify CSR Enable bit (E, bit 7) enables/disables core. Reset default 0. E=1 required before other registers.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">csr_write_cg::cp_enable</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">1.2</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">CSR IE Section 5.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify CSR Interrupt Enable bit (IE, bit 6) controls irq output. IE=1 raises irq on command completion.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">csr_write_cg::cp_irq_en</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">1.3</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">DPR Section 5.2</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify DPR (offset 0x01) read and write access. Write loads TX byte, read returns last received byte.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">dpr_access_cg::cp_dpr_op</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">1.4</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">CMDR Section 5.3</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify all CMD[2:0] command codes: Wait(000) Write(001) ReadAck(010) ReadNak(011) Start(100) Stop(101) SetBus(110).</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">1.5</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">CMDR DON Section 5.3</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify CMDR DON bit set on normal completion and cleared when new command issued. Reading CMDR clears irq.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_status_cg::cp_don</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
