    <Cell ss:StyleID="s73"><Data ss:Type="String">2.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">I2C Operations Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Covergroup verifying both write and read I2C operations observed by i2c_monitor.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_op_cg</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">CoverGroup</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.2</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">I2C Write Op Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify write_op bin - DUT generates START, address with W=0, data byte, STOP with slave ACK.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_op_cg::cp_op</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.3</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">I2C Read Op Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify read_op bin - DUT generates START, address with R=1, receives data from slave, stores in DPR.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_op_cg::cp_op</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.4</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Alternating Transfers Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify write-to-read and read-to-write transition bins. No FSM corruption between operations.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_op_transition_cg::cp_op_trans</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.5</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Byte FSM Start Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify FSM transitions Idle to Start Is Pending to Bus Is Taken on START command (CMDR=0x04).</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.6</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Byte FSM Write Byte Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify FSM enters Write Byte state on WRITE command (CMDR=0x01). Each bit sent via bit-level FSM.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.7</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Byte FSM Read Byte Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify FSM enters Read Byte state on READ_NAK command (CMDR=0x03). Returns Byte response with received data.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.8</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Byte FSM Stop Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify STOP command (CMDR=0x05) generates STOP condition, frees bus, returns FSM to Idle.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.9</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">SET_BUS Command Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify SET_BUS (CMDR=0x06) selects target I2C bus. Bus ID written to DPR before command.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_cmd_cg::cp_cmd</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.10</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">IRQ Clear Section 4.6</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify IRQ raised on completion when IE=1 and reading CMDR clears IRQ. Status bits retain values.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">cmdr_read_cg::cp_cmdr_read</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.11</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">I2C Address Range Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify core handles addresses across 7-bit space (0x00-0x7F). Bins cover four address quadrants.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_addr_cg::cp_addr</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">25</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">2</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.12</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">I2C Data Range Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify data bytes across full 8-bit range (0x00-0xFF). Bins include boundary values and intermediate ranges.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_data_cg::cp_data</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">50</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">2</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.13</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Data Zero Boundary Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify operation with data=0x00 all SDA bits zero. Core generates Write 0 bit-level commands for all 8 bits.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_data_cg::cp_data</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.14</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Data Max Boundary Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Verify operation with data=0xFF all SDA bits one. Core generates Write 1 bit-level commands for all 8 bits.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_data_cg::cp_data</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Coverpoint</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">100</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">1</Data></Cell>
   </Row>
   <Row ss:AutoFitHeight="0" ss:Height="37">
    <Cell ss:StyleID="s73"><Data ss:Type="String">2.15</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Op x Data Cross Section 3.1</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Cross coverage: both write and read ops exercise all data ranges. No data-dependent path difference.</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">i2c_op_data_cross_cg::cx_op_data</Data></Cell>
    <Cell ss:StyleID="s74"><Data ss:Type="String">Cross</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">1</Data></Cell>
    <Cell ss:StyleID="s75"><Data ss:Type="Number">50</Data></Cell>
    <Cell ss:StyleID="s76"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="String">bnoblea</Data></Cell>
    <Cell ss:StyleID="s77"><Data ss:Type="Number">2</Data></Cell>
   </Row>
